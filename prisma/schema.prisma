generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  image    String?   @default("https://res.cloudinary.com/dzjzj0r8c/image/upload/v1701304417/default-profile-picture-1_oyh5lq.png")
}
